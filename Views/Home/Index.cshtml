@{
    ViewData["Title"] = "Главная";
}

@section Styles {

    <link rel="stylesheet"
          href="~/css/main.css">

}

<main class="container">

    <section class="intro">

        <h1>
            Узнайте всё об уходе
            за комнатными растениями
        </h1>

        <h2>О проекте Greenhome</h2>

        <p>
            Greenhome — это сервис, в котором собраны рекомендации по уходу за комнатными растениями.
            Вы узнаете, как часто вашему растению нужен полив и пересадка, какая почва ему подойдет.
            Сделайте свою жизнь цветущей!
        </p>

        <h2>Каталог растений</h2>

        <p>
            Выбирайте интересующие вас категории растений и узнавайте, как ухаживать за вашими питомцами,
            а также присматривайте новых зелёных любимцев! Переходите в каталог или
            выбирайте интересующую вас группу растений в карусели ниже!
        </p>

        <!-- CAROUSEL -->
        <div class="carousel-wrapper">

            <button class="carousel-btn" id="prev">
                &#10094;
            </button>

            <div class="carousel-viewport">

                <div class="carousel-track">

                    <a class="carousel-item"
                       asp-controller="Plants"
                       asp-action="Category"
                       asp-route-id="succulents">

                        <img src="/img/main/succulent.jpg" alt="">

                        <p>Суккуленты</p>

                    </a>

                    <a class="carousel-item"
                       asp-controller="Plants"
                       asp-action="Category"
                       asp-route-id="cacti">

                        <img src="/img/main/cactus.jpg" alt="">

                        <p>Кактусы</p>

                    </a>

                    <a class="carousel-item"
                       asp-controller="Plants"
                       asp-action="Category"
                       asp-route-id="orchids">

                        <img src="/img/main/orchid.jpg" alt="">

                        <p>Орхидеи</p>

                    </a>

                </div>

            </div>

            <button class="carousel-btn" id="next">
                &#10095;
            </button>

        </div>

    </section>

</main>

<script src="/js/carousel.js"></script>