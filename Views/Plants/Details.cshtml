@model greenhome.Models.Plant

@{
    ViewData["Title"] = Model.Name;

    string sizeRu = Model.Size switch
    {
        "small" => "маленький",
        "medium" => "средний",
        "large" => "большой",
        _ => Model.Size
    };

    string wateringRu = Model.Watering switch
    {
        "rare" => "редкий",
        "medium" => "средний",
        "frequent" => "частый",
        _ => Model.Watering
    };

    string lightRu = Model.Light switch
    {
        "sun" => "светолюбивое",
        "shade" => "тенелюбивое",
        _ => Model.Light
    };
}

<link rel="stylesheet" href="~/css/details.css">

<!-- HEADER -->

<header class="header">

    <div class="logo">

        <img src="~/img/main/plant.png" alt="logo">

        <div>
            <h1>greenhome</h1>
            <p>уход за комнатными растениями</p>
        </div>

    </div>

    <nav class="nav">

        <a asp-controller="Home"
           asp-action="Index">

            Главная

        </a>

        <a asp-controller="Plants"
           asp-action="Index">

            Каталог

        </a>

    </nav>

</header>

<!-- MAIN -->

<main class="details-container">

    <div class="details-image">

        <img src="~/img/plants/@Model.Image"
             alt="@Model.Name">

    </div>

    <div class="details-info">

        <h1>@Model.Name</h1>

        <h2>@Model.LatinName</h2>

        <p class="description">
            @Model.Description
        </p>

        <div class="info-block">

            <p>
                <strong>Размер:</strong>
                @sizeRu
            </p>

            <p>
                <strong>Полив:</strong>
                @wateringRu
            </p>

            <p>
                <strong>Свет:</strong>
                @lightRu
            </p>

            <p>
                <strong>Почва:</strong>
                @Model.Soil
            </p>

            <p>
                <strong>Температура:</strong>
                @Model.Temperature °C
            </p>

        </div>

    </div>

</main>

<!-- FOOTER -->

<footer class="footer">

    <a href="#">
        FAQ
    </a>

    <a href="#">
        Контакты
    </a>

</footer>