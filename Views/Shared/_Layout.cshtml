<!DOCTYPE html>
<html lang="ru">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - greenhome
    </title>

    <link rel="stylesheet"
          href="~/css/site.css" />

    @RenderSection("Styles", required: false)

</head>

<body>

    <!-- HEADER -->

    <header class="header">

        <div class="logo">

            <img src="~/img/main/plant.png"
                 alt="logo">

            <div>

                <h1>greenhome</h1>

                <p>
                    уход за комнатными растениями
                </p>

            </div>

        </div>

        <nav class="nav">

            <a asp-controller="Home"
               asp-action="Index">

                Главная

            </a>

            <a asp-controller="Plants"
               asp-action="Index">

                Каталог

            </a>

            <a asp-controller="Plants"
               asp-action="Create">

                Добавить растение

            </a>

        </nav>

    </header>

    <!-- CONTENT -->

    <main>

        @RenderBody()

    </main>

    <!-- FOOTER -->

    <footer class="footer">

        greenhome 2026

    </footer>

</body>

</html>